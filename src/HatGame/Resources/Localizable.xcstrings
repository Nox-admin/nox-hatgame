      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Новая игра"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New Game"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新游戏"
          }
        }
      }
    },
    "home.rules": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Правила"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rules"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "规则"
          }
        }
      }
    },
    "rules.title": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Правила игры"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How to Play"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "游戏规则"
          }
        }
      }
    },
    "rules.1": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разделитесь на команды по 2+ игрока."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Split into teams of 2 or more players."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分成每队2人或以上的队伍。"
          }
        }
      }
    },
    "rules.2": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В шляпу попадают слова выбранной сложности."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Words of the chosen difficulty go into the hat."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所选难度的词语放入帽子中。"
          }
        }
      }
    },
    "rules.3": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Один игрок объясняет слово, остальные угадывают."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One player describes the word, others guess."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一名玩家描述单词，其他人猜测。"
          }
        }
      }
    },
    "rules.4": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "За каждое угаданное слово команда получает очко."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each guessed word earns the team one point."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每猜对一个词，队伍得一分。"
          }
        }
      }
    },
    "rules.5": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Время ограничено — успейте угадать как можно больше!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Time is limited — guess as many words as you can!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "时间有限——尽可能多猜几个词！"
          }
        }
      }
    },
    "rules.6": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Побеждает команда с наибольшим количеством очков."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The team with the most points wins."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "得分最多的队伍获胜。"
          }
        }
      }
    },
