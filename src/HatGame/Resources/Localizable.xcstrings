    "mode.ffa.description": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Один объясняет — все остальные угадывают. Побеждает тот, кто угадает больше."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One explains, everyone else guesses. Most guesses wins."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一人描述，其余人猜。猜中最多者获胜。"
          }
        }
      }
    },
    "mode.min_players": {
      "localizations": {
