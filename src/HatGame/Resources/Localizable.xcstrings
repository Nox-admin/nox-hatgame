    "players.duplicate_names": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У игроков не должно быть одинаковых имён"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Players must have unique names"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "玩家姓名不能重复"
