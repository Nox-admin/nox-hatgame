      }
    },
    "home.tagline": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Игра в слова для компании"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A party word game"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "聚会词语游戏"
          }
        }
      }
    },
