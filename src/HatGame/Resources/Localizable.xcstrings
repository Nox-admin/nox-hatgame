    "onboarding.slide2.title": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объясни слово"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Describe a Word"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "描述一个词"
          }
        }
      }
    },
    "onboarding.slide2.subtitle": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "не называя его. Команда угадывает!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "without saying it. Your team guesses!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不能说出来。队友来猜！"
          }
        }
      }
    },
    "onboarding.slide3.title": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Собери друзей"
