    "mode.pairs.description": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Игроки объясняют по парам. Каждый побывает объяснителем."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Players explain in pairs. Everyone takes a turn explaining."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "玩家两两配对描述，每人都有机会描述。"
          }
        }
      }
    },
    "mode.ffa.title": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все сразу"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
