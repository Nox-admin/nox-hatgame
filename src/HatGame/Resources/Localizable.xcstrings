    "mode.teams.description": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разбейтесь на команды. Команды соревнуются между собой."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Form teams. Teams compete against each other."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "组成队伍，队伍之间相互竞争。"
          }
        }
      }
    },
    "mode.pairs.title": {
